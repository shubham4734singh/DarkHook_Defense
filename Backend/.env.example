# DarkHook Defense - Environment Configuration Example
# Copy this file to .env and fill in your values
# IMPORTANT: Never commit your .env file with real credentials!

# MongoDB Atlas Configuration
# Get this from: MongoDB Atlas -> Cluster -> Connect -> Connect your application
# Replace <username>, <password>, and <cluster> with your actual values
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<database>

# Database Name
DATABASE_NAME=Phishing

# JWT Secret Key (generate a secure random key for production)
# Run: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-secret-key-here

# JWT Algorithm
JWT_ALGORITHM=HS256

# JWT Access Token Expiration (minutes)
# 1440 minutes = 1 day
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Frontend URL (for CORS)
# For local development: http://localhost:5173
# For production on Vercel: https://your-app.vercel.app
FRONTEND_URL=http://localhost:5173

# Local backend port
# Default is 8000. If you already have something running on 8000 (e.g., Splunk),
# set this to 8001 (and update Frontend VITE_API_BASE_URL accordingly).
PORT=8000

# Backend URL
# Production (Render): https://darkhook-defense.onrender.com
# Local: http://localhost:8000 (or http://localhost:8001 if PORT=8001)
BACKEND_URL=http://localhost:8000

# -------------------------
# Email OTP Configuration
# -------------------------
# RECOMMENDED: Use Brevo API (works on free hosting like Render)
# Get your API key from: https://app.brevo.com/settings/keys/api
# This bypasses SMTP port blocking on free hosting tiers
BREVO_API_KEY=your_brevo_api_key_here

# FALLBACK: SMTP Configuration (if API key not provided)
# Note: Many free hosting providers block SMTP ports 25, 465, 587
# Brevo (Sendinblue) SMTP relay
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USERNAME=your_brevo_login_email
SMTP_PASSWORD=your_brevo_smtp_key
SMTP_FROM=DarkHook Defense <your_verified_sender@domain.com>

# STARTTLS (recommended with port 587)
SMTP_USE_TLS=true

# SMTP timeout in seconds (increase if you get timeout errors)
SMTP_TIMEOUT_SECONDS=30

# Optional: SMTP over SSL (port 465). Some hosts block STARTTLS/587.
# SMTP_USE_SSL=true
# SMTP_SSL_PORT=465

# Network tuning / fallback
SMTP_TIMEOUT_SECONDS=5
SMTP_FALLBACK_TO_SSL=true


# OTP / verification behavior
REQUIRE_EMAIL_VERIFICATION=true
OTP_TTL_MINUTES=10
OTP_RESEND_COOLDOWN_SECONDS=60
OTP_MAX_ATTEMPTS=5

# Development-only helper: when enabled, OTP is not emailed (printed to logs)
# OTP_EMAIL_SENDING_DISABLED=true

# ====================
# IMPORTANT: To fix MongoDB Atlas connection errors:
# ====================
#
# 1. Go to https://cloud.mongodb.com/v2/
# 2. Select your project
# 3. Click "Network Access" in the left sidebar
# 4. Click "Add IP Address"
# 5. Add your current IP address (find it at https://whatismyip.com)
#    OR use "0.0.0.0/0" for development (not recommended for production)
# 6. Wait 2-5 minutes for changes to take effect
#
# If you see error: "TLSV1_ALERT_INTERNAL_ERROR: SSL alert number 80"
# This typically means your IP is not whitelisted in MongoDB Atlas
